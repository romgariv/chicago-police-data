# chicago-police-data/individual/shootings-cpd-feb2016/import/src/Makefile

# the input/ data is found in Dropbox in the same path.

# these outputs seem to have been generated by SPSS, so
# here there's no actual work. We store the xls inputs in input/,
# but this structure simply documents that the csvs were created
# in a structure that's prior to the implementation of principled
# data processing.

all: output/dat_feb2016.csv.gz \
	output/dat_feb2016_victimdetainee.csv.gz \
	output/dat_feb2016_officer.csv.gz

# we name the outputs as the target
output/dat_feb2016.csv.gz: \
		frozen/dat_feb2016.csv
	gzip -k $< && mv frozen/dat_feb2016.csv.gz output/

output/dat_feb2016_victimdetainee.csv.gz: \
		frozen/dat_feb2016_victimdetainee.csv
	gzip -k $< && mv frozen/dat_feb2016_victimdetainee.csv.gz output/

output/dat_feb2016_officer.csv.gz: \
		frozen/dat_feb2016_officer.csv
	gzip -k $< && mv frozen/dat_feb2016_officer.csv.gz output/

# this should have dependencies on the data, but that's tricky
# bc the data are in dropbox remotely.
output/train.html: \
		note/import.ipynb
	jupyter nbconvert \
		--ExecutePreprocessor.timeout=600  \
		--to html \
		--execute $<
	mv note/import.html output/

# done.
